    %res9 = call i64 @factorial(i64 5)
    store i64 %res9, i64* %res_8_ptr
    %tmp10 = load i64, i64* %res_8_ptr
    %ign11 = call i64 (i8*, ...) @printf(i8* getelementptr inbounds ([5 x i8], [5 x i8]* @fmt_int, i32 0, i32 0), i64 %tmp10)
