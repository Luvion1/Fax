    let terms = 5;
    let mut sum = 0;
    let mut k = 1;
    while k <= terms {
        let denominator = power_int(2, k) - 1;
        sum = sum + (10000 / denominator);  // Scale by 10000
        k = k + 1;
    }
    print(sum);
}

