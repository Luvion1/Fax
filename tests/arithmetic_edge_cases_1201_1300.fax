fn test_sigma_function_generalized() {
    // σ_k(n) = sum of k-th powers of divisors of n
    let n = 4;
    let k = 2;
    let mut sum = 0;
    let mut i = 1;
    while i <= n {
        if n % i == 0 {
            sum = sum + power_int(i, k);
        }
        i = i + 1;
    }
    print(sum);
}

fn test_riemann_zeta_function() {
    // ζ(s) = ∑(1/n^s) for n=1 to ∞
    // For s=2: ζ(2) = π^2/6 ≈ 1.6449
    // Calculate partial sum for this discrete simulation
    let s = 2;
    let terms = 10;
    let mut sum = 0;
    let mut n = 1;
    while n <= terms {
        let denom = power_int(n, s);
        sum = sum + (10000 / denom);  // Scale by 10000
        n = n + 1;
    }
    print(sum);
}

