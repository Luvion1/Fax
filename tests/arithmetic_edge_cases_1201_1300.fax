fn test_lagranges_four_square_theorem() {
    // Every natural number is sum of four integer squares
    let n = 7;
    // 7 = 2^2 + 1^2 + 1^2 + 1^2
    print(1);  // Always possible
}

fn test_fermats_sum_of_two_squares_theorem() {
    // A prime p can be expressed as sum of two squares iff p = 2 or p ≡ 1 (mod 4)
    let p = 5;  // 5 ≡ 1 (mod 4), and 5 = 2^2 + 1^2
    let condition = if p == 2 || p % 4 == 1 { 1 } else { 0 };
    print(condition);
}

fn test_legendres_three_square_theorem() {
    // A natural number n is sum of 3 squares iff n ≠ 4^a(8b + 7)
    let n = 7;
    let mut temp = n;
    while temp % 4 == 0 {
        temp = temp / 4;
    }
    let is_form = if temp % 8 == 7 { 1 } else { 0 };
    let can_be_represented = if is_form { 0 } else { 1 };
    print(can_be_represented);
}

fn test_pentagonal_number_theorem() {
    // Euler's identity: ∏(1-x^n) = ∑(-1)^k*x^(k*(3k-1)/2)
    // For this test, verify for first few terms
    let k = 1;
    let exponent = k * (3 * k - 1) / 2;
    print(exponent);
}

fn test_frobenius_problem() {
    // Find largest number that cannot be expressed as a linear combination of given coprime numbers
    // For a=3, b=5: largest impossible number is ab - a - b = 15 - 3 - 5 = 7
    let a = 3;
    let b = 5;
    let frobenius_number = a * b - a - b;
    print(frobenius_number);
}

fn test_sylvesters_sequence() {
    // s(n) = s(n-1)*(s(n-1)-1) + 1, with s(0) = 2
    let mut s = 2;
    let mut i = 0;
    while i < 4 {
        s = s * (s - 1) + 1;
        i = i + 1;
    }
    print(s);
}

fn test_erdos_borwein_constant() {
