fn test_madhava_leibniz_formula() {
    // π/4 = 1 - 1/3 + 1/5 - 1/7 + ...
    // Calculate partial sum
    let terms = 1000;
    let mut sum = 0;
    let mut n = 0;
    while n < terms {
        let sign = if n % 2 == 0 { 1 } else { -1 };
        let denominator = 2 * n + 1;
        sum = sum + (sign * (4000 / denominator));  // Scale by 4000 to get π*1000
        n = n + 1;
    }
    print(sum);
}

fn test_wallis_product() {
    // π/2 = ∏(2n/(2n-1) * 2n/(2n+1)) for n=1 to ∞
    // Calculate partial product
    let terms = 100;
    let mut product = 1000;  // Start with 1000 to scale
    let mut n = 1;
    while n <= terms {
        let numerator = 2 * n;
        let denom1 = 2 * n - 1;
        let denom2 = 2 * n + 1;
        product = (product * numerator * numerator) / (denom1 * denom2);
        n = n + 1;
    }
    print(product);  // This should approximate π/2 * 1000
}

fn test_basel_problem() {
    // ∑(1/n²) for n=1 to ∞ = π²/6
    let terms = 1000;
    let mut sum = 0;
    let mut n = 1;
    while n <= terms {
        let denominator = n * n;
        sum = sum + (10000 / denominator);  // Scale by 10000
        n = n + 1;
    }
    print(sum);  // This should approximate π²/6 * 10000 ≈ 1644.9
}

fn test_aperys_constant() {
    // ζ(3) = ∑(1/n³) for n=1 to ∞ ≈ 1.2020569
    let terms = 1000;
    let mut sum = 0;
    let mut n = 1;
    while n <= terms {
        let denominator = n * n * n;
        sum = sum + (1000 / denominator);  // Scale by 1000
        n = n + 1;
    }
    print(sum);  // This should approximate ζ(3) * 1000 ≈ 1202
}

fn test_catalans_constant() {
    // G = ∑((-1)^n/(2n+1)²) for n=0 to ∞ ≈ 0.91596559
    let terms = 1000;
    let mut sum = 0;
    let mut n = 0;
    while n < terms {
        let sign = if n % 2 == 0 { 1 } else { -1 };
        let denominator = (2 * n + 1) * (2 * n + 1);
        sum = sum + (sign * (1000 / denominator));  // Scale by 1000
        n = n + 1;
    }
    print(sum);  // This should approximate G * 1000 ≈ 916
}

fn test_eulers_constant() {
    // γ = lim(n→∞)[∑(1/k) for k=1 to n - ln(n)] ≈ 0.57721566
    let n = 1000;
    let mut harmonic_sum = 0;
    let mut k = 1;
    while k <= n {
        harmonic_sum = harmonic_sum + (10000 / k);  // Scale by 10000
        k = k + 1;
    }
    // Approximate ln(n) * 10000
    let ln_n_scaled = 6908;  // ln(1000) ≈ 6.908
    let euler_gamma_scaled = harmonic_sum - ln_n_scaled;
    print(euler_gamma_scaled);  // Should approximate γ * 10000
}

