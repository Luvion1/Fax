// Arithmetic Edge Cases 1201-1300

fn test_continued_fraction_representation() {
    // Represent a number as continued fraction
    let num = 45;
    let den = 17;
    let mut a = num;
    let mut b = den;
    let mut result = 0;
    while b != 0 {
        let quotient = a / b;
        result = result + quotient;  // Just counting the terms for this test
        let temp = a % b;
        a = b;
        b = temp;
    }
    print(result);
}

fn test_simple_continued_fraction() {
    // Simple continued fraction for sqrt(2) = [1; 2, 2, 2, ...]
    let mut approx = 1;
    let iterations = 5;
    let mut i = 0;
    while i < iterations {
        approx = 1 + 1 / (1 + approx);  // Simplified approximation
        i = i + 1;
    }
    print(approx);
}

fn test_convergents_of_continued_fraction() {
    // Calculate convergents of continued fraction
    let a0 = 3;
    let a1 = 7;
    let a2 = 15;
    // Calculate first few convergents of [a0; a1, a2, ...]
    let p0 = a0;
    let q0 = 1;
    let p1 = a1 * a0 + 1;
    let q1 = a1;
    print(p0);
    print(q0);
    print(p1);
    print(q1);
}

fn test_pell_equation_solution() {
    // Solve x^2 - D*y^2 = 1 for D=2
    // Fundamental solution is (3, 2): 3^2 - 2*2^2 = 9 - 8 = 1
    let x = 3;
    let y = 2;
    let d = 2;
    let result = x*x - d*y*y;
    print(result);
}

fn test_generalized_pell_equation() {
    // Solve x^2 - D*y^2 = N for general N
    let x = 3;
    let y = 1;
    let d = 2;
    let n = 7;
    let result = x*x - d*y*y;
    let is_solution = if result == n { 1 } else { 0 };
    print(is_solution);
}

fn test_chakravala_method() {
    // Ancient Indian method for solving Pell equations
    // For x^2 - 61*y^2 = 1, the minimal solution is (1766319049, 226153980)
    // Using simplified approach
    let x = 1766319049;
    let y = 226153980;
    let d = 61;
    let result = x*x - d*y*y;
    print(result);
}

fn test_brahmagupta_identity() {
    // (a^2 + nb^2)(c^2 + nd^2) = (ac + nbd)^2 + n(ad - bc)^2
    let a = 1;
    let b = 2;
    let c = 2;
    let d = 1;
    let n = 3;
    
    let lhs = (a*a + n*b*b) * (c*c + n*d*d);
    let ac_nbd = a*c + n*b*d;
    let ad_bc = a*d - b*c;
    let rhs = ac_nbd*ac_nbd + n*ad_bc*ad_bc;
    
    print(lhs);
    print(rhs);
}

fn test_eulers_totient_function() {
    // φ(n) = n * ∏(1 - 1/p) for prime factors p of n
    let n = 12;
    let mut result = n;
    let mut p = 2;
    let mut temp_n = n;
    while p * p <= temp_n {
        if temp_n % p == 0 {
            while temp_n % p == 0 {
                temp_n = temp_n / p;
            }
            result = result - result / p;
        }
        p = p + 1;
    }
    if temp_n > 1 {
        result = result - result / temp_n;
    }
    print(result);
}

fn test_carmichael_function() {
    // λ(n) - smallest positive integer m such that a^m ≡ 1 (mod n) for all a coprime to n
    let n = 8;
    // For n = 2^k where k ≥ 3, λ(n) = 2^(k-2)
    let lambda = if n >= 8 && (n & (n-1)) == 0 { n / 4 } else { n };  // Simplified
    print(lambda);
}

fn test_jordan_totient_function() {
    // J_k(n) = n^k * ∏(1 - 1/p^k) for prime factors p of n
    let n = 6;
    let k = 1;
    let mut result = power_int(n, k);
    let mut p = 2;
    let mut temp_n = n;
    while p * p <= temp_n {
        if temp_n % p == 0 {
            while temp_n % p == 0 {
                temp_n = temp_n / p;
            }
            let factor = power_int(p, k);
            result = result - result / factor;
        }
        p = p + 1;
    }
    if temp_n > 1 {
        let factor = power_int(temp_n, k);
        result = result - result / factor;
    }
    print(result);
}

