fn test_stern_brocot_tree() {
    // A tree containing all positive rationals exactly once
    // Root is 1/1, left child of a/b is a/(a+b), right child is (a+b)/b
    let a = 1;
    let b = 1;
    let left_child_num = a;
    let left_child_den = a + b;
    let right_child_num = a + b;
    let right_child_den = b;
    print(left_child_num);
    print(left_child_den);
    print(right_child_num);
    print(right_child_den);
}

