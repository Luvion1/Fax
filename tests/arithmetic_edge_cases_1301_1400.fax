fn test_discrete_logarithm_problem() {
    // Given g, h, and n, find x such that g^x ≡ h (mod n)
    let g = 2;
    let h = 3;
    let n = 5;
    let mut x = 0;
    let mut found = 0;
    while x < n {
        let mut power = 1;
        let mut exp = x;
        let mut base = g % n;
        while exp > 0 {
            if exp % 2 == 1 {
                power = (power * base) % n;
            }
            exp = exp / 2;
            base = (base * base) % n;
        }
        if power == h {
            found = x;
            break;
        }
        x = x + 1;
    }
    print(found);
}

