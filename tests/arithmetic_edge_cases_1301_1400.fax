fn test_integer_factorization_trial_division() {
    let n = 35;
    let mut factors = [0, 0];
    let mut count = 0;
    let mut divisor = 2;
    let mut temp_n = n;
    while divisor * divisor <= temp_n {
        while temp_n % divisor == 0 {
            factors[count] = divisor;
            count = count + 1;
            temp_n = temp_n / divisor;
        }
        divisor = divisor + 1;
    }
    if temp_n > 1 {
        factors[count] = temp_n;
        count = count + 1;
    }
    print(factors[0]);
    print(factors[1]);
}

