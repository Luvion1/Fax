// Error Handling and Exception Edge Cases 801-900

fn test_no_error_occurs() {
    let result = safe_operation(10, 5);
    print(result);
}

fn safe_operation(a: int, b: int) -> int {
    return a / b;
}

fn test_division_by_zero_simulation() {
    let a = 10;
    let b = 0;
    if b == 0 {
        print(-1);  // Error indicator
    } else {
        print(a / b);
    }
}

fn test_null_pointer_dereference_simulation() {
    let ptr = null;
    if ptr == null {
        print(-1);  // Error indicator
    } else {
        print(1);  // Success
    }
}

fn test_array_out_of_bounds_simulation() {
    let arr = [1, 2, 3];
    let index = 5;
    if index < len(arr) {
        print(arr[index]);
    } else {
        print(-1);  // Error indicator
    }
}

fn test_negative_array_index_simulation() {
    let arr = [10, 20, 30];
    let index = -1;
    if index >= 0 && index < len(arr) {
        print(arr[index]);
    } else {
        print(-1);  // Error indicator
    }
}

fn test_integer_overflow_simulation() {
    let a = 2147483647;  // Max int value
    let b = 1;
    if a > 2147483647 - b {
        print(-1);  // Overflow detected
    } else {
        print(a + b);
    }
}

fn test_integer_underflow_simulation() {
    let a = -2147483648;  // Min int value
    let b = 1;
    if a < -2147483648 + b {
        print(-1);  // Underflow detected
    } else {
        print(a - b);
    }
}

fn test_stack_overflow_simulation() {
    let depth = 1000;
    if depth > 100 {  // Arbitrary limit
        print(-1);  // Stack overflow
    } else {
        print(depth);
    }
}

fn test_heap_overflow_simulation() {
    let requested_size = 1000000000;  // 1GB
    let available_memory = 500000000;  // 500MB
    if requested_size > available_memory {
        print(-1);  // Heap overflow
    } else {
        print(requested_size);
    }
}

fn test_buffer_overflow_simulation() {
    let buffer = [0, 0, 0, 0, 0];  // Size 5
    let write_position = 10;  // Beyond bounds
    if write_position < len(buffer) {
        print(1);  // Safe
    } else {
        print(-1);  // Buffer overflow
    }
}

fn test_buffer_underflow_simulation() {
    let buffer = [1, 2, 3, 4, 5];
    let read_position = -1;  // Negative
    if read_position >= 0 && read_position < len(buffer) {
        print(buffer[read_position]);
    } else {
        print(-1);  // Buffer underflow
    }
}

fn test_invalid_cast_simulation() {
    let value = 42;
    // Simulate type checking
    if value >= 0 {
        print(value);  // Valid cast
    } else {
        print(-1);  // Invalid cast
    }
}

fn test_uninitialized_variable_simulation() {
