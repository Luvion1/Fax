fn test_matrix_multiplication_performance() {
    let a = [[1, 2, 3], [4, 5, 6]];
    let b = [[7, 8], [9, 10], [11, 12]];
    let mut result = [[0, 0], [0, 0]];
    let rows_a = 2;
    let cols_a = 3;
    let cols_b = 2;
    let mut operations = 0;
    let mut i = 0;
    while i < rows_a {
        let mut j = 0;
        while j < cols_b {
            let mut k = 0;
            while k < cols_a {
                result[i][j] = result[i][j] + a[i][k] * b[k][j];
                operations = operations + 2;  // 1 mult + 1 add
                k = k + 1;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    print(operations);
}

fn test_fibonacci_iterative_performance() {
    let n = 20;
    let mut a = 0;
    let mut b = 1;
    let mut count = 2;
    let mut operations = 0;
    if n <= 0 {
        print(0);
    } else if n == 1 {
        print(1);
    } else {
        while count < n {
            let temp = a + b;
            a = b;
            b = temp;
            operations = operations + 1;
            count = count + 1;
        }
        print(operations);
    }
}

fn test_fibonacci_recursive_performance() {
    let n = 10;
    let result = fib_recursive(n, 0);
    print(result);
}

fn fib_recursive(n: int, ops: int) -> int {
    if n <= 1 {
        return ops + 1;
    }
    return fib_recursive(n - 1, ops + 1) + fib_recursive(n - 2, ops + 1) - ops;
}

fn test_factorial_iterative_performance() {
    let n = 10;
    let mut result = 1;
    let mut i = 1;
    let mut operations = 0;
    while i <= n {
        result = result * i;
        operations = operations + 1;
        i = i + 1;
    }
    print(operations);
}

fn test_factorial_recursive_performance() {
    let n = 8;
    let result = fact_recursive(n, 0);
    print(result);
}

fn fact_recursive(n: int, ops: int) -> int {
    if n <= 1 {
        return ops;
    }
    return fact_recursive(n - 1, ops + 1);
}

fn test_prime_check_performance() {
    let num = 97;
    let mut is_prime = true;
    let mut divisor = 2;
    let mut operations = 0;
    while divisor * divisor <= num {
        operations = operations + 1;
        if num % divisor == 0 {
            is_prime = false;
        }
        divisor = divisor + 1;
    }
    print(operations);
}

fn test_gcd_euclidean_performance() {
    let mut a = 48;
    let mut b = 18;
    let mut operations = 0;
    while b != 0 {
        let temp = b;
        b = a % b;
        a = temp;
        operations = operations + 1;
    }
    print(operations);
}

fn test_lcm_calculation_performance() {
    let x = 12;
    let y = 18;
    let mut a = x;
    let mut b = y;
    let mut ops_gcd = 0;
    while b != 0 {
        let temp = b;
        b = a % b;
        a = temp;
        ops_gcd = ops_gcd + 1;
    }
    let gcd = a;
    let lcm = (x * y) / gcd;
    print(ops_gcd);
}

fn test_power_calculation_performance() {
    let base = 2;
    let exp = 10;
    let mut result = 1;
    let mut i = 0;
    let mut operations = 0;
    while i < exp {
        result = result * base;
        operations = operations + 1;
        i = i + 1;
    }
    print(operations);
}

fn test_power_logarithmic_performance() {
    let base = 2;
    let mut exp = 10;
    let mut result = 1;
    let mut operations = 0;
    while exp > 0 {
        operations = operations + 1;
        if exp % 2 == 1 {
            result = result * base;
            operations = operations + 1;
        }
        base = base * base;
        exp = exp / 2;
    }
    print(operations);
}

fn test_string_search_performance() {
    let text = "abcdefghijk";
    let pattern = "def";
    let mut found = false;
    let mut comparisons = 0;
    let text_len = len(text);
    let pat_len = len(pattern);
    let mut i = 0;
    while i <= text_len - pat_len && !found {
        let mut j = 0;
        while j < pat_len {
            comparisons = comparisons + 1;
            if text[i + j] != pattern[j] {
                break;
            }
            j = j + 1;
        }
        if j == pat_len {
            found = true;
        }
        i = i + 1;
    }
    print(comparisons);
}

