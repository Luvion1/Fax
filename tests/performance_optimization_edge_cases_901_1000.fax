}

fn test_strength_reduction_simulation() {
    let arr = [1, 2, 3, 4, 5];
    let mut i = 0;
    let mut address = 0;  // Simulate array indexing
    let element_size = 4;  // Size of each element
    while i < len(arr) {
        // Instead of arr[i] which computes base + i*size
        // Strength reduction would optimize this
        address = i * element_size;
        i = i + 1;
    }
    print(address);
}

