// Performance and Optimization Edge Cases 901-1000

fn test_linear_search_performance() {
    let arr = [1, 5, 10, 15, 20, 25, 30];
    let target = 25;
    let mut i = 0;
    let mut comparisons = 0;
    while i < len(arr) {
        comparisons = comparisons + 1;
        if arr[i] == target {
            break;
        }
        i = i + 1;
    }
    print(comparisons);
}

fn test_binary_search_performance() {
    let arr = [1, 5, 10, 15, 20, 25, 30, 35, 40, 45];
    let target = 30;
    let mut left = 0;
    let mut right = len(arr) - 1;
    let mut comparisons = 0;
    let mut found = false;
    
    while left <= right && !found {
        comparisons = comparisons + 1;
        let mid = (left + right) / 2;
        if arr[mid] == target {
            found = true;
        } else if arr[mid] < target {
            left = mid + 1;
        } else {
            right = mid - 1;
        }
    }
    print(comparisons);
}

fn test_bubble_sort_performance() {
    let mut arr = [64, 34, 25, 12, 22, 11, 90];
    let n = len(arr);
    let mut comparisons = 0;
    let mut swaps = 0;
    let mut i = 0;
    while i < n {
        let mut j = 0;
        while j < n - i - 1 {
            comparisons = comparisons + 1;
            if arr[j] > arr[j + 1] {
                // Swap
                let temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
                swaps = swaps + 1;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    print(comparisons);
    print(swaps);
}

fn test_selection_sort_performance() {
    let mut arr = [64, 34, 25, 12, 22, 11, 90];
    let n = len(arr);
    let mut comparisons = 0;
    let mut swaps = 0;
    let mut i = 0;
    while i < n {
        let mut min_idx = i;
        let mut j = i + 1;
        while j < n {
            comparisons = comparisons + 1;
            if arr[j] < arr[min_idx] {
                min_idx = j;
            }
            j = j + 1;
        }
        if min_idx != i {
            let temp = arr[i];
            arr[i] = arr[min_idx];
            arr[min_idx] = temp;
            swaps = swaps + 1;
        }
        i = i + 1;
    }
    print(comparisons);
    print(swaps);
}

fn test_insertion_sort_performance() {
    let mut arr = [64, 34, 25, 12, 22, 11, 90];
    let n = len(arr);
    let mut comparisons = 0;
    let mut shifts = 0;
    let mut i = 1;
    while i < n {
        let key = arr[i];
        let mut j = i - 1;
        while j >= 0 && arr[j] > key {
            comparisons = comparisons + 1;
            arr[j + 1] = arr[j];
            shifts = shifts + 1;
            j = j - 1;
        }
        if j >= 0 {
            comparisons = comparisons + 1;
        }
        arr[j + 1] = key;
        i = i + 1;
    }
    print(comparisons);
    print(shifts);
}

