    let mut i = 0;
    while i < len(arr) {
        result1 = result1 + arr[i];
        i = i + 1;
    }
    i = 0;
    while i < len(arr) {
        result2 = result2 + arr[i] * 2;
        i = i + 1;
    }
    print(result1 + result2);
}

fn test_loop_fission_simulation() {
