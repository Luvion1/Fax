}

fn test_string_repeat_simulation() {
    let s = "ab";
    let count = 3;
    // Simulate repeating string
    print(len(s) * count);
}

fn test_string_escape_chars_simulation() {
    let s = "hello\nworld";
    // Simulate escape sequences
    print(len(s));
}

fn test_string_unicode_simulation() {
    let s = "café";
    // Simulate Unicode characters
    print(len(s));
}

fn test_string_multiline_simulation() {
    let s = "line1\nline2\nline3";
    print(len(s));
}

fn test_string_with_null_bytes_simulation() {
    let s = "test\0test";
    print(len(s));
}

fn test_string_index_access() {
    let s = "abcdef";
    print(s[0]);
    print(s[3]);
    print(s[5]);
}

fn test_string_index_out_of_bounds_simulation() {
    let s = "abc";
    let index = 5;
    if index < len(s) {
        print(s[index]);
    } else {
        print(-1);  // Error indicator
    }
}

fn test_string_iteration_simulation() {
    let s = "xyz";
    let mut i = 0;
    while i < len(s) {
        print(s[i]);
        i = i + 1;
    }
}

fn test_string_reverse_simulation() {
    let s = "abcde";
    let len_s = len(s);
    let mut i = len_s - 1;
    while i >= 0 {
        print(s[i]);
        if i == 0 {
            break;
        }
        i = i - 1;
    }
}

fn test_string_palindrome_check_simulation() {
    let s = "racecar";
    let len_s = len(s);
    let mut is_palindrome = true;
    let mut i = 0;
    while i < len_s / 2 {
        if s[i] != s[len_s - 1 - i] {
            is_palindrome = false;
        }
        i = i + 1;
    }
    print(is_palindrome);
}

fn test_string_anagram_simulation() {
    let s1 = "listen";
    let s2 = "silent";
    // Simulate anagram check
    print(len(s1));
    print(len(s2));
}

fn test_string_vowel_consonant_count_simulation() {
    let s = "hello";
    let vowels = "aeiouAEIOU";
    let mut vowel_count = 0;
    let mut consonant_count = 0;
    let mut i = 0;
    while i < len(s) {
        let mut is_vowel = false;
        let mut j = 0;
        while j < len(vowels) {
            if s[i] == vowels[j] {
                is_vowel = true;
            }
            j = j + 1;
        }
        if is_vowel {
            vowel_count = vowel_count + 1;
        } else {
            consonant_count = consonant_count + 1;
        }
        i = i + 1;
    }
    print(vowel_count);
    print(consonant_count);
}

fn test_string_word_count_simulation() {
    let s = "hello world test";
    let mut word_count = 1;  // At least one word
    let mut i = 0;
    while i < len(s) {
        if s[i] == ' ' {
            word_count = word_count + 1;
        }
        i = i + 1;
    }
    print(word_count);
}

fn test_string_sentence_count_simulation() {
    let s = "Hello world. How are you? I am fine!";
    let mut sent_count = 0;
    let mut i = 0;
    while i < len(s) {
        if s[i] == '.' || s[i] == '?' || s[i] == '!' {
            sent_count = sent_count + 1;
        }
        i = i + 1;
    }
    print(sent_count);
}

