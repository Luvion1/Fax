// String and Character Edge Cases 501-600

fn test_empty_string() {
    let s = "";
    print(len(s));
}

fn test_single_char_string() {
    let s = "a";
    print(len(s));
    print(s[0]);
}

fn test_multi_char_string() {
    let s = "hello";
    print(len(s));
    print(s[0]);
    print(s[4]);
}

fn test_string_with_spaces() {
    let s = "hello world";
    print(len(s));
}

fn test_string_with_special_chars() {
    let s = "!@#$%^&*()";
    print(len(s));
}

fn test_string_with_numbers() {
    let s = "12345";
    print(len(s));
}

fn test_string_with_mixed_content() {
    let s = "abc123!@#";
    print(len(s));
}

fn test_string_concatenation_simulation() {
    let s1 = "hello";
    let s2 = "world";
    // Simulate concatenation by printing separately
    print(len(s1));
    print(len(s2));
}

fn test_string_comparison_eq() {
    let s1 = "test";
    let s2 = "test";
    let equal = compare_strings(s1, s2);
    print(equal);
}

fn test_string_comparison_neq() {
    let s1 = "test";
    let s2 = "testing";
    let equal = compare_strings(s1, s2);
    print(equal);
}

fn compare_strings(s1: str, s2: str) -> bool {
    let len1 = len(s1);
    let len2 = len(s2);
    if len1 != len2 {
        return false;
    }
    let mut i = 0;
    while i < len1 {
        if s1[i] != s2[i] {
            return false;
        }
        i = i + 1;
    }
    return true;
}

fn test_string_upper_lower_simulation() {
    let s = "Hello";
    // Simulate case conversion
    print(len(s));
}

fn test_string_substring_simulation() {
    let s = "hello world";
    let start = 6;
    let end = 11;
    // Simulate substring extraction
    print(end - start);
}

fn test_string_trim_simulation() {
    let s = "  hello  ";
