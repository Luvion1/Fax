// Bersarang kompleks
fn test91() {
    if 1 == 1 {
        if 2 == 2 {
            if 3 == 3 {
                print(1);
            }
        }
    }
}

fn test92() {
    let mut x = 0;
    if x == 0 {
        x = 1;
        if x == 1 {
            x = 2;
            if x == 2 {
                x = 3;
            }
        }
    }
    print(x);
}

fn test93() {
    let mut i = 0;
    while i < 1 {
        let mut j = 0;
        while j < 1 {
            let mut k = 0;
            while k < 1 {
                print(1);
                k = k + 1;
            }
            j = j + 1;
        }
        i = i + 1;
    }
}

// Kondisi batas untuk loop
fn test94() {
    let mut i = 0;
    while i < 1 {  // exactly one iteration
        print(i);
        i = i + 1;
    }
}

fn test95() {
