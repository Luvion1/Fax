    let arr = [[0]];
    print(arr[0][0]);
}

// Fungsi rekursif (kedalaman terbatas)
fn factorial(n: i64) -> i64 {
    if n <= 1 {
        return 1;
    }
    return n * factorial(n - 1);
}

fn test71() {
    print(factorial(1));  // base case
}

fn test72() {
    print(factorial(3));  // small case
}

fn countdown(n: i64) {
    if n > 0 {
        print(n);
        countdown(n - 1);
    }
}

fn test73() {
    countdown(2);
}

// Konsep assignment ganda (disimulasikan)
fn test74() {
    let a = 5;
    let b = a;
    let c = b;
    print(a + b + c);
}

fn test75() {
    let x = 1;
    let y = x;
    x = 10;
    print(y);  // should still be 1
}

