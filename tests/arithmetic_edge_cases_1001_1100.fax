    let a = 15;
    let b = 25;
    let gcd_result = gcd_simulation(a, b);
    let ratio_a = a / gcd_result;
    let ratio_b = b / gcd_result;
    print(ratio_a);
    print(ratio_b);
}

fn gcd_simulation(x: int, y: int) -> int {
    let mut a = x;
    let mut b = y;
    while b != 0 {
        let temp = b;
        b = a % b;
        a = temp;
    }
    return a;
}

