}

fn test_modular_inverse() {
    let a = 3;
    let m = 11;  // Find x such that (a * x) % m = 1
    let mut x = 1;
    let mut found = 0;
    while x < m {
        if (a * x) % m == 1 {
            found = x;
            break;
        }
        x = x + 1;
    }
    print(found);
}

fn test_modular_exponentiation() {
    let base = 3;
    let exponent = 4;
    let modulus = 5;
    let mut result = 1;
    let mut exp = exponent;
    let mut b = base % modulus;
    while exp > 0 {
        if exp % 2 == 1 {
            result = (result * b) % modulus;
        }
        exp = exp / 2;
        b = (b * b) % modulus;
    }
    print(result);
}

fn test_totient_function() {
    let n = 9;  // φ(9) = 9 * (1 - 1/3) = 6
    let mut result = n;
    let mut p = 2;
    let mut temp_n = n;
    while p * p <= temp_n {
        if temp_n % p == 0 {
            while temp_n % p == 0 {
                temp_n = temp_n / p;
            }
            result = result - result / p;
        }
        p = p + 1;
    }
    if temp_n > 1 {
        result = result - result / temp_n;
    }
    print(result);
}

fn test_legendre_symbol() {
    let a = 2;
    let p = 7;  // Compute (a/p) where p is prime
    // Using Euler's criterion: a^((p-1)/2) ≡ (a/p) (mod p)
    let exp = (p - 1) / 2;
    let mut result = 1;
    let mut e = exp;
    let mut base = a % p;
    while e > 0 {
        if e % 2 == 1 {
            result = (result * base) % p;
        }
        e = e / 2;
        base = (base * base) % p;
    }
    // Convert to -1, 0, 1 representation
    if result == p - 1 {
        result = -1;
    } else if result > 1 {
        result = 0;  // This is a simplification
    }
    print(result);
}

