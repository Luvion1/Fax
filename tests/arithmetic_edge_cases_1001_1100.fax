fn test_floating_point_simulation_addition() {
    let a_whole = 10;
    let a_frac = 5;  // Represents 10.5
    let b_whole = 5;
    let b_frac = 3;  // Represents 5.3
    let whole_result = a_whole + b_whole;
    let frac_result = a_frac + b_frac;
    print(whole_result);
    print(frac_result);
}

fn test_floating_point_simulation_multiplication() {
    let a_whole = 3;
    let a_frac = 5;  // Represents 3.5
    let b_whole = 2;
    let b_frac = 0;  // Represents 2.0
    // (a_whole + a_frac/10) * (b_whole + b_frac/10)
    let cross1 = (a_whole * b_frac) / 10;
    let cross2 = (a_frac * b_whole) / 10;
    let whole_part = a_whole * b_whole;
    let frac_part = (a_frac * b_frac) / 10;
    let result = whole_part + cross1 + cross2 + frac_part;
    print(result);
}

