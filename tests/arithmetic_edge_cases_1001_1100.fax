fn test_range_calculation() {
    let nums = [5, 2, 8, 1, 9];
    let mut min_val = nums[0];
    let mut max_val = nums[0];
    let mut i = 1;
    while i < len(nums) {
        if nums[i] < min_val {
            min_val = nums[i];
        }
        if nums[i] > max_val {
            max_val = nums[i];
        }
        i = i + 1;
    }
    let range = max_val - min_val;
    print(range);
}

fn test_variance_calculation() {
    let nums = [2, 4, 4, 4, 5, 5, 7, 9];
    let n = len(nums);
    let mut sum = 0;
    let mut i = 0;
    while i < n {
        sum = sum + nums[i];
        i = i + 1;
    }
    let mean = sum / n;
    
    let mut sum_sq_diff = 0;
    i = 0;
    while i < n {
        let diff = nums[i] - mean;
        sum_sq_diff = sum_sq_diff + diff * diff;
        i = i + 1;
    }
    let variance = sum_sq_diff / n;
    print(variance);
}

fn test_standard_deviation_calculation() {
    let variance = 4;  // From previous test
    // Approximate square root
    let mut guess = variance / 2;
    let mut i = 0;
    while i < 5 {
        guess = (guess + variance / guess) / 2;
        i = i + 1;
    }
    print(guess);
}

