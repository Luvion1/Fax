fn test_pell_equation_simulation() {
    // x^2 - n*y^2 = 1, for n=2: x^2 - 2*y^2 = 1
    // Fundamental solution (3,2): 3^2 - 2*2^2 = 9 - 8 = 1
    let x = 3;
    let y = 2;
    let n = 2;
    let result = x*x - n*y*y;
    print(result);
}

fn test_perfect_number_check() {
    let num = 6;  // 1 + 2 + 3 = 6
    let mut sum = 0;
    let mut i = 1;
    while i < num {
        if num % i == 0 {
            sum = sum + i;
        }
        i = i + 1;
    }
    let is_perfect = if sum == num { 1 } else { 0 };
    print(is_perfect);
}

fn test_armstrong_number_check() {
    let num = 153;  // 1^3 + 5^3 + 3^3 = 1 + 125 + 27 = 153
    let digits = 3;
    let mut temp = num;
    let mut sum = 0;
    while temp > 0 {
        let digit = temp % 10;
        let mut power = 1;
        let mut i = 0;
        while i < digits {
            power = power * digit;
            i = i + 1;
        }
        sum = sum + power;
        temp = temp / 10;
    }
    let is_armstrong = if sum == num { 1 } else { 0 };
    print(is_armstrong);
}

fn test_harshad_number_check() {
    let num = 18;  // 1 + 8 = 9, and 18 % 9 = 0
    let mut temp = num;
    let mut digit_sum = 0;
    while temp > 0 {
        digit_sum = digit_sum + temp % 10;
        temp = temp / 10;
    }
    let is_harshad = if digit_sum != 0 && num % digit_sum == 0 { 1 } else { 0 };
    print(is_harshad);
}

fn test_carmichael_number_check() {
    // 561 is the smallest Carmichael number
    let num = 561;
    // Check if it's composite and satisfies Fermat's little theorem
    // For simplicity, just verify it's composite
    let is_composite = if num % 3 == 0 { 1 } else { 0 };  // 561 = 3 * 187
    print(is_composite);
}

fn test_collatz_conjecture() {
    let mut n = 7;
    let mut steps = 0;
    while n != 1 {
        if n % 2 == 0 {
            n = n / 2;
        } else {
            n = 3 * n + 1;
        }
        steps = steps + 1;
    }
    print(steps);
}

fn test_amicable_numbers() {
    let a = 220;
    let b = 284;
    
    // Sum of proper divisors of a
    let mut sum_a = 0;
    let mut i = 1;
    while i < a {
        if a % i == 0 {
            sum_a = sum_a + i;
        }
        i = i + 1;
    }
    
    // Sum of proper divisors of b
    let mut sum_b = 0;
    i = 1;
    while i < b {
        if b % i == 0 {
            sum_b = sum_b + i;
        }
        i = i + 1;
    }
    
    let are_amicable = if sum_a == b && sum_b == a { 1 } else { 0 };
    print(are_amicable);
}

