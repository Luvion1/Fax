fn test_root_approximation_square() {
    let num = 25;
    let mut guess = num / 2;
    let mut i = 0;
    while i < 5 {  // 5 iterations for approximation
        guess = (guess + num / guess) / 2;
        i = i + 1;
    }
    print(guess);
}

fn test_root_approximation_cube() {
    let num = 27;
    let mut guess = num / 3;  // Initial guess
    let mut i = 0;
    while i < 5 {
        guess = (2 * guess + num / (guess * guess)) / 3;  // Newton's method for cube root
        i = i + 1;
    }
    print(guess);
}

