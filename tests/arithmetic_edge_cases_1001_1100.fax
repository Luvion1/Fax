}

fn test_discrete_logarithm() {
    let base = 2;
    let result = 3;
    let modulus = 5;
    // Find x such that base^x ≡ result (mod modulus)
    let mut x = 0;
    let mut found = -1;
    while x < modulus {
        let mut power = 1;
        let mut exp = x;
        let mut b = base % modulus;
        while exp > 0 {
            if exp % 2 == 1 {
                power = (power * b) % modulus;
            }
            exp = exp / 2;
            b = (b * b) % modulus;
        }
        if power == result {
            found = x;
            break;
        }
        x = x + 1;
    }
    print(found);
}

fn test_primitive_root() {
    let p = 7;  // Find a primitive root modulo p
    // A primitive root g has order p-1
    let g = 3;  // 3 is a primitive root of 7
    let mut order = 1;
    let mut power = g % p;
    while power != 1 && order < p - 1 {
        power = (power * g) % p;
        order = order + 1;
    }
    let is_primitive = if order == p - 1 { 1 } else { 0 };
    print(is_primitive);
}

