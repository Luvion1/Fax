fn test_mersenne_prime_check() {
    let p = 3;  // Check if 2^3 - 1 = 7 is prime
    let mersenne = (1 << p) - 1;  // 2^p - 1
    // Simple primality check for small numbers
    let is_prime = if mersenne == 7 { 1 } else { 0 };  // 7 is prime
    print(is_prime);
}

fn test_fermat_number() {
    let n = 0;  // F_0 = 2^(2^0) + 1 = 2^1 + 1 = 3
    let power = (1 << (1 << n));  // 2^(2^n)
    let fermat_num = power + 1;
    print(fermat_num);
}

fn test_wilsons_theorem() {
    let p = 5;  // Check if (p-1)! ≡ -1 (mod p), for prime p
    let mut factorial = 1;
    let mut i = 1;
    while i < p {
        factorial = factorial * i;
        i = i + 1;
    }
    let result = factorial % p;
    let wilson_check = if result == p - 1 { 1 } else { 0 };
    print(wilson_check);
}

fn test_chinese_remainder_theorem() {
    // Solve x ≡ 2 (mod 3), x ≡ 3 (mod 5), x ≡ 2 (mod 7)
    // Solution: x ≡ 23 (mod 105)
    let moduli = [3, 5, 7];
    let remainders = [2, 3, 2];
    // For this example, we'll just verify x=23 satisfies all
    let x = 23;
    let cond1 = if x % moduli[0] == remainders[0] { 1 } else { 0 };
    let cond2 = if x % moduli[1] == remainders[1] { 1 } else { 0 };
    let cond3 = if x % moduli[2] == remainders[2] { 1 } else { 0 };
    print(cond1);
    print(cond2);
    print(cond3);
}

