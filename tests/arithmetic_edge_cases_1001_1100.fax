// Arithmetic Edge Cases 1001-1100

fn test_arithmetic_overflow_scenarios() {
    let max_int = 2147483647;
    let result = if max_int + 1 > max_int { -1 } else { max_int + 1 };
    print(result);
}

fn test_arithmetic_underflow_scenarios() {
    let min_int = -2147483648;
    let result = if min_int - 1 < min_int { -1 } else { min_int - 1 };
    print(result);
}

