fn test_prime_factorization_simulation() {
    let num = 60;
    let mut n = num;
    let mut factor = 2;
    let mut factors_found = 0;
    while n > 1 {
        if n % factor == 0 {
            n = n / factor;
            factors_found = factors_found + 1;
        } else {
            factor = factor + 1;
        }
    }
    print(factors_found);
}

