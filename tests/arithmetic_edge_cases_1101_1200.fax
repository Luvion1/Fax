fn test_perfect_number_generation() {
    // Perfect numbers are of the form 2^(p-1) * (2^p - 1) where 2^p - 1 is prime
    let p = 2;  // 2^2 - 1 = 3 (prime), so 2^(2-1) * 3 = 2 * 3 = 6
    let mersenne = power_int(2, p) - 1;
    let perfect = power_int(2, p - 1) * mersenne;
    print(perfect);
}

fn test_abundant_number_classification() {
    let n = 12;  // Proper divisors: 1,2,3,4,6. Sum = 16 > 12
    let mut sum = 0;
    let mut i = 1;
    while i < n {
        if n % i == 0 {
            sum = sum + i;
        }
        i = i + 1;
    }
    let is_abundant = if sum > n { 1 } else { 0 };
    print(is_abundant);
}

