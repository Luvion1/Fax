}

fn test_harmonic_divisor_number() {
    // A number whose divisors have an integer harmonic mean
    // 6 is harmonic: divisors are 1,2,3,6. Harmonic mean = 4/(1/1+1/2+1/3+1/6) = 4/(4/2) = 2
    let n = 6;
    let mut sum_reciprocals_scaled = 0;
    let mut count = 0;
    let mut i = 1;
    while i <= n {
        if n % i == 0 {
            sum_reciprocals_scaled = sum_reciprocals_scaled + (n / i);  // Scaled by n
            count = count + 1;
        }
        i = i + 1;
    }
    let harmonic_mean_scaled = (count * n) / sum_reciprocals_scaled;
    print(harmonic_mean_scaled);
}

