fn test_powerful_number() {
    // A number where for every prime p dividing n, p^2 also divides n
    // 36 = 2^2 * 3^2, both primes appear squared
    let n = 36;
    let mut temp = n;
    let mut p = 2;
    let mut is_powerful = 1;
    while p * p <= temp {
        if temp % p == 0 {
            temp = temp / p;
            if temp % p != 0 {
                is_powerful = 0;  // p divides n but p^2 doesn't
                break;
            }
        }
        p = p + 1;
    }
    print(is_powerful);
}

