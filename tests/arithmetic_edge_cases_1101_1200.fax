fn test_superabundant_number() {
    // A number n is superabundant if (sigma(n))/n > (sigma(k))/k for all k < n
    // For n=6: sigma(6)/6 = 12/6 = 2, which is greater than previous ratios
    let n = 6;
    let sigma_n = sum_of_divisors(n);
    let ratio_n = (sigma_n * 100) / n;  // Scaled ratio
    print(ratio_n);
}

fn sum_of_divisors(n: int) -> int {
    let mut sum = 0;
    let mut i = 1;
    while i <= n {
        if n % i == 0 {
            sum = sum + i;
        }
        i = i + 1;
    }
    return sum;
}

fn test_highly_composite_number() {
    // A number with more divisors than any smaller number
    // 12 has 6 divisors: 1,2,3,4,6,12 - more than any number less than 12
    let n = 12;
    let divisor_count = count_divisors(n);
    print(divisor_count);
}

fn count_divisors(n: int) -> int {
    let mut count = 0;
    let mut i = 1;
    while i <= n {
        if n % i == 0 {
            count = count + 1;
        }
        i = i + 1;
    }
    return count;
}

fn test_rough_number() {
    // An n-rough number is one whose prime factors are all ≥ n
    // 11 is 7-rough because its prime factor (11) is ≥ 7
    let num = 11;
    let roughness = 7;
    let is_rough = if num >= roughness { 1 } else { 0 };
    print(is_rough);
}

fn test_smooth_number() {
    // A number whose prime factors are all ≤ B (B-smooth)
    // 12 = 2^2 * 3 is 3-smooth
    let num = 12;
    let smoothness = 3;
    let is_smooth = if num % 5 != 0 && num % 7 != 0 { 1 } else { 0 };  // Simplified check
    print(is_smooth);
}

fn test_sphenic_number() {
    // A product of three distinct primes
    // 30 = 2 * 3 * 5
    let n = 30;
    let mut count = 0;
    let mut temp_n = n;
    let mut p = 2;
    while p * p <= temp_n {
        if temp_n % p == 0 {
            count = count + 1;
            temp_n = temp_n / p;
            // Check if divisible by p again (not distinct)
            if temp_n % p == 0 {
                count = 100;  // Mark as invalid
                break;
            }
        }
        p = p + 1;
    }
    if temp_n > 1 {
        count = count + 1;
    }
    let is_sphenic = if count == 3 { 1 } else { 0 };
    print(is_sphenic);
}

fn test_nice_prime() {
    // A prime p where (p-1)/2 is also prime (Sophie Germain prime)
    // 5 is nice because (5-1)/2 = 2 is also prime
    let p = 5;
    let is_prime_p = is_prime_func(p);
    let half_p_minus_1 = (p - 1) / 2;
    let is_prime_half = is_prime_func(half_p_minus_1);
    let is_nice = if is_prime_p && is_prime_half { 1 } else { 0 };
    print(is_nice);
}

fn is_prime_func(n: int) -> bool {
    if n <= 1 {
        return false;
    }
    if n <= 3 {
        return true;
    }
    if n % 2 == 0 || n % 3 == 0 {
        return false;
    }
    let mut i = 5;
    while i * i <= n {
        if n % i == 0 || n % (i + 2) == 0 {
            return false;
        }
        i = i + 6;
    }
    return true;
}

fn test_safe_prime() {
    // A prime p where (p-1)/2 is also prime
    // Same as Sophie Germain prime concept
    let p = 7;  // (7-1)/2 = 3, which is prime
    let half_p_minus_1 = (p - 1) / 2;
    let is_safe = if is_prime_func(p) && is_prime_func(half_p_minus_1) { 1 } else { 0 };
    print(is_safe);
}

