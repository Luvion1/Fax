fn test_zuckerman_number() {
    // A number divisible by the product of its digits
    // 115 is Zuckerman: 1*1*5 = 5, and 115 % 5 = 0
    let n = 115;
    let mut product = 1;
    let mut temp = n;
    while temp > 0 {
        let digit = temp % 10;
        if digit != 0 {  // Avoid multiplication by 0
            product = product * digit;
        }
        temp = temp / 10;
    }
    let is_zuckerman = if product != 0 && n % product == 0 { 1 } else { 0 };
    print(is_zuckerman);
}

fn test_harshad_number() {
    // A number divisible by the sum of its digits
    // 18 is Harshad: 1+8=9, and 18 % 9 = 0
    let n = 18;
    let mut digit_sum = 0;
    let mut temp = n;
    while temp > 0 {
        digit_sum = digit_sum + temp % 10;
        temp = temp / 10;
    }
    let is_harshad = if digit_sum != 0 && n % digit_sum == 0 { 1 } else { 0 };
    print(is_harshad);
}

fn test_moran_number() {
    // A number N that divided by the sum of its digits gives a prime
    // 117: 1+1+7=9, 117/9=13 (prime)
    let n = 117;
    let mut digit_sum = 0;
    let mut temp = n;
    while temp > 0 {
        digit_sum = digit_sum + temp % 10;
        temp = temp / 10;
    }
    let quotient = if digit_sum != 0 { n / digit_sum } else { -1 };
    let is_moran = if quotient > 0 && is_prime_func(quotient) { 1 } else { 0 };
    print(is_moran);
}

fn test_keith_number() {
    // A number in a sequence where each term is sum of previous terms
    // 197: 1, 9, 7, 17, 33, 57, 107, 197
    let n = 197;
    let digits = [1, 9, 7];
    let mut sequence = [1, 9, 7, 0, 0, 0, 0, 0];
    let mut i = 3;
    while i < 8 {
        sequence[i] = sequence[i-1] + sequence[i-2] + sequence[i-3];
        if sequence[i] == n {
            print(1);  // Is Keith number
            return;
        }
        if sequence[i] > n {
            print(0);  // Not Keith number
            return;
        }
        i = i + 1;
    }
    print(0);
}

fn test_narcissistic_number() {
    // A number that is the sum of its own digits each raised to the power of the number of digits
    // 153 = 1^3 + 5^3 + 3^3 = 1 + 125 + 27 = 153
    let n = 153;
    let num_digits = count_digits(n);
    let mut temp = n;
    let mut sum = 0;
    while temp > 0 {
        let digit = temp % 10;
        sum = sum + power_int(digit, num_digits);
        temp = temp / 10;
    }
    let is_narcissistic = if sum == n { 1 } else { 0 };
    print(is_narcissistic);
}

fn count_digits(n: int) -> int {
    if n == 0 {
        return 1;
    }
    let mut count = 0;
    let mut temp = n;
    while temp > 0 {
        count = count + 1;
        temp = temp / 10;
    }
    return count;
}

fn test_perfect_digital_invariant() {
    // A number that is equal to the sum of a fixed power of its digits
    // Same as narcissistic number
    test_narcissistic_number();
}

fn test_munchausen_number() {
    // A number equal to the sum of its digits raised to each digit's own power
    // 3435 = 3^3 + 4^4 + 3^3 + 5^5 = 27 + 256 + 27 + 3125 = 3435
    let n = 3435;
    let mut temp = n;
    let mut sum = 0;
    while temp > 0 {
        let digit = temp % 10;
        if digit > 0 {
            sum = sum + power_int(digit, digit);
        } else {
            sum = sum + 0;  // 0^0 is treated as 0 in this context
        }
        temp = temp / 10;
    }
    let is_munchausen = if sum == n { 1 } else { 0 };
    print(is_munchausen);
}

fn test_factorion() {
    // A number equal to the sum of factorials of its digits
    // 145 = 1! + 4! + 5! = 1 + 24 + 120 = 145
    let n = 145;
    let mut temp = n;
    let mut sum = 0;
    while temp > 0 {
        let digit = temp % 10;
        sum = sum + factorial_calc(digit);
        temp = temp / 10;
    }
    let is_factorion = if sum == n { 1 } else { 0 };
    print(is_factorion);
}

