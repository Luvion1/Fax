// Arithmetic Edge Cases 1101-1200

fn test_arithmetic_series_sum() {
    let start = 1;
    let end = 100;
    let sum = (end * (end + 1)) / 2 - ((start - 1) * start) / 2;
    print(sum);
}

fn test_geometric_series_sum() {
    let first_term = 1;
    let ratio = 2;
    let terms = 10;
    let numerator = first_term * (power_int(ratio, terms) - 1);
    let denominator = ratio - 1;
    let sum = if denominator != 0 { numerator / denominator } else { -1 };
    print(sum);
}

fn power_int(base: int, exp: int) -> int {
    let mut result = 1;
    let mut i = 0;
    while i < exp {
        result = result * base;
        i = i + 1;
    }
    return result;
}

fn test_arithmetic_mean_of_series() {
    let start = 1;
    let end = 10;
    let sum = (end * (end + 1)) / 2;
    let count = end - start + 1;
    let mean = sum / count;
    print(mean);
}

fn test_weighted_mean_of_series() {
    let values = [1, 2, 3, 4, 5];
    let weights = [1, 2, 3, 4, 5];
    let mut weighted_sum = 0;
    let mut weight_sum = 0;
    let mut i = 0;
    while i < len(values) {
        weighted_sum = weighted_sum + values[i] * weights[i];
        weight_sum = weight_sum + weights[i];
        i = i + 1;
    }
    let weighted_mean = if weight_sum != 0 { weighted_sum / weight_sum } else { -1 };
    print(weighted_mean);
}

fn test_harmonic_mean_calculation() {
    let values = [2, 4, 1];  // Reciprocals: 1/2, 1/4, 1/1
    let n = len(values);
    let mut sum_reciprocals = 0;
    let mut i = 0;
    while i < n {
        sum_reciprocals = sum_reciprocals + (1000 / values[i]);  // Scale by 1000
        i = i + 1;
    }
    let harmonic_mean = if sum_reciprocals != 0 { (n * 1000) / sum_reciprocals } else { -1 };
    print(harmonic_mean);
}

fn test_geometric_mean_calculation() {
    let values = [2, 8];  // Geometric mean = sqrt(2*8) = 4
    let n = len(values);
    let mut product = 1;
    let mut i = 0;
    while i < n {
        product = product * values[i];
        i = i + 1;
    }
    // For 2 values, geometric mean is sqrt(product)
    let mut guess = product / 2;
    let mut iter = 0;
    while iter < 5 {
        guess = (guess + product / guess) / 2;
        iter = iter + 1;
    }
    print(guess);
}

fn test_quadratic_formula() {
    // Solve ax^2 + bx + c = 0
    let a = 1;
    let b = -5;
    let c = 6;  // x^2 - 5x + 6 = 0, roots are 2 and 3
    let discriminant = b * b - 4 * a * c;
    if discriminant >= 0 {
        let sqrt_discriminant = approx_sqrt(discriminant);
        let root1 = (-b + sqrt_discriminant) / (2 * a);
        let root2 = (-b - sqrt_discriminant) / (2 * a);
        print(root1);
        print(root2);
    } else {
        print(-1);  // Complex roots
    }
}

fn approx_sqrt(n: int) -> int {
    if n <= 1 {
        return n;
    }
    let mut guess = n / 2;
    let mut i = 0;
    while i < 5 {
        guess = (guess + n / guess) / 2;
        i = i + 1;
    }
    return guess;
}

fn test_cubic_equation_roots() {
    // x^3 - 6x^2 + 11x - 6 = 0, roots are 1, 2, 3
    let a = 1;
    let b = -6;
    let c = 11;
    let d = -6;
    // For this test, just verify the polynomial at known roots
    let x = 1;
    let result = a * x * x * x + b * x * x + c * x + d;
    print(result);
}

fn test_synthetic_division() {
    // Divide x^2 - 5x + 6 by (x - 2)
    // Coefficients: [1, -5, 6], divisor: 2
    let coeffs = [1, -5, 6];
    let divisor = 2;
    let mut result = [0, 0];
    result[0] = coeffs[0];  // Leading coefficient
    result[1] = coeffs[1] + result[0] * divisor;
    let remainder = coeffs[2] + result[1] * divisor;
    print(result[0]);
    print(result[1]);
    print(remainder);
}

fn test_polynomial_evaluation_horner() {
    // Evaluate 2x^3 + 3x^2 + 4x + 5 at x = 2
    let coeffs = [2, 3, 4, 5];  // 2x^3 + 3x^2 + 4x + 5
    let x = 2;
    let mut result = coeffs[0];
    let mut i = 1;
    while i < len(coeffs) {
        result = result * x + coeffs[i];
        i = i + 1;
    }
    print(result);
}

fn test_binomial_coefficient() {
    // Calculate C(n, k) = n! / (k! * (n-k)!)
    let n = 5;
    let k = 2;
    let numerator = factorial_calc(n);
    let denominator = factorial_calc(k) * factorial_calc(n - k);
    let binomial = if denominator != 0 { numerator / denominator } else { -1 };
    print(binomial);
}

fn factorial_calc(n: int) -> int {
    if n <= 1 {
        return 1;
    }
    return n * factorial_calc(n - 1);
}

fn test_pascals_triangle_row() {
    let n = 5;  // Generate row 5 of Pascal's triangle
    let mut i = 0;
    while i <= n {
        let coeff = factorial_calc(n) / (factorial_calc(i) * factorial_calc(n - i));
        print(coeff);
        i = i + 1;
    }
}

fn test_multinomial_coefficient() {
    // Calculate multinomial coefficient for (n, k1, k2, k3) where k1+k2+k3=n
    let n = 6;
    let k1 = 2;
    let k2 = 2;
    let k3 = 2;
    let numerator = factorial_calc(n);
    let denominator = factorial_calc(k1) * factorial_calc(k2) * factorial_calc(k3);
    let multinomial = if denominator != 0 { numerator / denominator } else { -1 };
    print(multinomial);
}

fn test_fibonacci_by_formula() {
    // Using Binet's formula: F(n) = (φ^n - ψ^n) / √5
    // Where φ = (1+√5)/2 and ψ = (1-√5)/2
    // For this discrete simulation, use iterative approach
    let n = 10;
    let mut a = 0;
    let mut b = 1;
    let mut i = 0;
    while i < n {
        let temp = a + b;
        a = b;
        b = temp;
        i = i + 1;
    }
    print(a);
}

fn test_lucas_sequence() {
    // Lucas sequence: L(0)=2, L(1)=1, L(n)=L(n-1)+L(n-2)
    let n = 8;
    let mut a = 2;
    let mut b = 1;
    let mut i = 0;
    while i < n {
        let temp = a + b;
        a = b;
        b = temp;
        i = i + 1;
    }
    print(a);
}

fn test_pell_sequence() {
    // Pell sequence: P(0)=0, P(1)=1, P(n)=2*P(n-1)+P(n-2)
    let n = 7;
    let mut a = 0;
    let mut b = 1;
    let mut i = 0;
    while i < n {
        let temp = 2 * b + a;
        a = b;
        b = temp;
        i = i + 1;
    }
    print(a);
}

