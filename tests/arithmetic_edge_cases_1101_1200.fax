fn test_palindromic_number() {
    let n = 121;
    let reversed = reverse_number(n);
    let is_palindromic = if n == reversed { 1 } else { 0 };
    print(is_palindromic);
}

fn reverse_number(n: int) -> int {
    let mut rev = 0;
    let mut temp = n;
    while temp > 0 {
        rev = rev * 10 + temp % 10;
        temp = temp / 10;
    }
    return rev;
}

fn test_lychrel_number_candidate() {
    // A number that doesn't form a palindrome when repeatedly added to its reverse
    // 196 is the smallest candidate
    let n = 196;
    let mut temp = n;
    let mut i = 0;
    while i < 10 {  // Limited iterations for simulation
        let reversed = reverse_number(temp);
        if temp == reversed {
            print(0);  // Forms palindrome
            return;
        }
        temp = temp + reversed;
        i = i + 1;
    }
    print(1);  // Didn't form palindrome in 10 iterations
}

