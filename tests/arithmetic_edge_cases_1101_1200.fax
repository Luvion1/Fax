fn test_sublime_number() {
    // A number where both the number of divisors and sum of divisors are perfect numbers
    // Only two known: 12 and a very large number
    let n = 12;
    let divisor_count = count_divisors(n);
    let divisor_sum = sum_of_divisors(n);
    // Check if both are perfect numbers
    let is_div_count_perfect = is_perfect_number(divisor_count);
    let is_div_sum_perfect = is_perfect_number(divisor_sum);
    let is_sublime = if is_div_count_perfect && is_div_sum_perfect { 1 } else { 0 };
    print(is_sublime);
}

fn is_perfect_number(n: int) -> bool {
    if n <= 1 {
        return false;
    }
    let mut sum = 0;
    let mut i = 1;
    while i < n {
        if n % i == 0 {
            sum = sum + i;
        }
        i = i + 1;
    }
    return sum == n;
}

