fn test_weird_number() {
    // A weird number is abundant but not semiperfect
    // 70 is the smallest weird number: abundant (1+2+5+7+10+14+35 = 74 > 70) but not semiperfect
    let n = 70;
    let mut sum = 0;
    let mut i = 1;
    while i < n {
        if n % i == 0 {
            sum = sum + i;
        }
        i = i + 1;
    }
