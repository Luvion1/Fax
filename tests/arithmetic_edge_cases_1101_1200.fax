fn test_catalan_sequence() {
    // C(n) = (2n)! / ((n+1)! * n!)
    let n = 4;
    let numerator = factorial_calc(2 * n);
    let denominator = factorial_calc(n + 1) * factorial_calc(n);
    let catalan = if denominator != 0 { numerator / denominator } else { -1 };
    print(catalan);
}

fn test_derangement_calculation() {
    // Number of derangements: !n = n! * sum((-1)^k / k!) for k=0 to n
    let n = 4;
    let n_fact = factorial_calc(n);
    let mut sum = 0;
    let mut k = 0;
    while k <= n {
        let k_fact = factorial_calc(k);
        let sign = if k % 2 == 0 { 1 } else { -1 };
        sum = sum + sign * (n_fact / k_fact);  // Multiply by n! and divide by k!
        k = k + 1;
    }
    print(sum);
}

