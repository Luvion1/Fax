fn test_amicable_pair_generation() {
    let a = 220;
    let b = 284;
    
    // Sum of proper divisors of a
    let mut sum_a = 0;
    let mut i = 1;
    while i < a {
        if a % i == 0 {
            sum_a = sum_a + i;
        }
        i = i + 1;
    }
    
    // Sum of proper divisors of b
    let mut sum_b = 0;
    i = 1;
    while i < b {
        if b % i == 0 {
            sum_b = sum_b + i;
        }
        i = i + 1;
    }
    
    let are_amicable = if sum_a == b && sum_b == a { 1 } else { 0 };
    print(are_amicable);
}

