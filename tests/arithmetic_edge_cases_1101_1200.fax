fn test_wieferich_prime() {
    // A prime p such that p^2 divides 2^(p-1) - 1
    // Known examples: 1093, 3511
    let p = 1093;
    let exp = p - 1;
    let mut power = 1;
    let mut base = 2;
    let mut e = exp;
    while e > 0 {
        if e % 2 == 1 {
            power = (power * base) % (p * p);
        }
        e = e / 2;
        base = (base * base) % (p * p);
    }
    let minus_one = if power == 1 { 1 } else { 0 };
    print(minus_one);
}

