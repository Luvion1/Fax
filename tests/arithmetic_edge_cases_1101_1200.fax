fn test_primorial_number() {
    // The product of the first n primes
    // For n=3: 2*3*5 = 30
    let n = 3;
    let mut result = 1;
    let mut count = 0;
    let mut candidate = 2;
    while count < n {
        if is_prime_func(candidate) {
            result = result * candidate;
            count = count + 1;
        }
        candidate = candidate + 1;
    }
    print(result);
}

fn test_factorial_prime() {
    // A prime that is one less or one more than a factorial
    // 5 = 3! - 1 = 6 - 1
    let factorial = 6;  // 3!
    let prime1 = factorial - 1;
    let prime2 = factorial + 1;
    let is_prime1 = is_prime_func(prime1);
    let is_prime2 = is_prime_func(prime2);
    let is_factorial_prime = if is_prime1 || is_prime2 { 1 } else { 0 };
    print(is_factorial_prime);
}

fn test_primorial_prime() {
    // A prime that is one less or one more than a primorial
    let primorial = 6;  // 2*3 = 6
    let prime1 = primorial - 1;
    let prime2 = primorial + 1;
    let is_prime1 = is_prime_func(prime1);
    let is_prime2 = is_prime_func(prime2);
    let is_primorial_prime = if is_prime1 || is_prime2 { 1 } else { 0 };
    print(is_primorial_prime);
}

fn test_wagstaff_prime() {
    // A prime of the form (2^p + 1)/3 where p is prime
    // For p=3: (2^3 + 1)/3 = 9/3 = 3
    let p = 3;
    let numerator = power_int(2, p) + 1;
    let wagstaff = if numerator % 3 == 0 { numerator / 3 } else { -1 };
    let is_wagstaff_prime = if wagstaff > 0 && is_prime_func(wagstaff) { 1 } else { 0 };
    print(is_wagstaff_prime);
}

fn test_sophie_germain_prime() {
