fn test_friendly_number() {
    // Two numbers with the same abundancy index (sigma(n)/n)
    // 6 and 28 both have abundancy index 2
    let a = 6;
    let b = 28;
    let sigma_a = sum_of_divisors(a);
    let sigma_b = sum_of_divisors(b);
    let ratio_a = (sigma_a * b);  // Cross multiply to avoid fractions
    let ratio_b = (sigma_b * a);
    let are_friendly = if ratio_a == ratio_b { 1 } else { 0 };
    print(are_friendly);
}

