        print(prefix_sum[i]);
        i = i + 1;
    }
}

fn test_parallel_histogram_simulation() {
    let data = [1, 2, 2, 3, 3, 3];
    let mut histogram = [0, 0, 0, 0];  // For values 0-3
    let mut i = 0;
    while i < len(data) {
        if data[i] < len(histogram) {
            histogram[data[i]] = histogram[data[i]] + 1;
        }
        i = i + 1;
    }
    i = 0;
    while i < len(histogram) {
        print(histogram[i]);
        i = i + 1;
    }
}

fn test_parallel_matrix_multiply_simulation() {
    let a = [[1, 2], [3, 4]];
    let b = [[5, 6], [7, 8]];
    let mut result = [[0, 0], [0, 0]];
    let rows_a = 2;
    let cols_a = 2;
    let cols_b = 2;
    let mut i = 0;
    while i < rows_a {
        let mut j = 0;
        while j < cols_b {
            let mut k = 0;
            while k < cols_a {
                result[i][j] = result[i][j] + a[i][k] * b[k][j];
                k = k + 1;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    i = 0;
    while i < rows_a {
        let mut j = 0;
        while j < cols_b {
            print(result[i][j]);
            j = j + 1;
        }
        i = i + 1;
    }
}

