}

fn test_starvation_simulation() {
    let mut priority_queue = [1, 2, 3, 4, 5];
    let mut high_priority_tasks = 0;
    let mut low_priority_tasks = 0;
    let mut i = 0;
    while i < len(priority_queue) {
        if priority_queue[i] <= 2 {
            high_priority_tasks = high_priority_tasks + 1;
        } else {
            low_priority_tasks = low_priority_tasks + 1;
        }
        i = i + 1;
    }
    print(high_priority_tasks);
    print(low_priority_tasks);
}

fn test_livelock_simulation() {
    let mut state1 = 1;
    let mut state2 = 2;
    let mut attempts = 0;
    while state1 == state2 && attempts < 5 {
        // Both threads yield to each other
        if state1 == 1 {
            state1 = 2;
        } else {
            state1 = 1;
        }
        attempts = attempts + 1;
    }
    print(attempts);
}

