fn test_parallel_search_simulation() {
    let data = [10, 20, 30, 40, 50];
    let target = 30;
    let mut found = false;
    let mut i = 0;
    while i < len(data) && !found {
        if data[i] == target {
            found = true;
        }
        i = i + 1;
    }
    print(found);
}

fn test_parallel_binary_search_simulation() {
    let sorted_data = [1, 3, 5, 7, 9, 11, 13];
    let target = 7;
    let mut left = 0;
    let mut right = len(sorted_data) - 1;
    let mut found = false;
    while left <= right && !found {
        let mid = (left + right) / 2;
        if sorted_data[mid] == target {
            found = true;
        } else if sorted_data[mid] < target {
            left = mid + 1;
        } else {
            right = mid - 1;
        }
    }
    print(found);
}

fn test_parallel_quick_sort_simulation() {
    let mut data = [3, 6, 8, 10, 1, 2, 1];
    // Simple quicksort simulation
    quicksort_simulation(&mut data, 0, len(data) - 1);
    let mut i = 0;
    while i < len(data) {
        print(data[i]);
        i = i + 1;
    }
}

fn quicksort_simulation(arr: &mut [int], low: int, high: int) {
    if low < high {
        let pi = partition_simulation(arr, low, high);
        quicksort_simulation(arr, low, pi - 1);
        quicksort_simulation(arr, pi + 1, high);
    }
}

fn partition_simulation(arr: &mut [int], low: int, high: int) -> int {
    let pivot = arr[high];
    let mut i = low - 1;
    let mut j = low;
    while j < high {
        if arr[j] <= pivot {
            i = i + 1;
            // Swap arr[i] and arr[j]
            let temp = arr[i];
            arr[i] = arr[j];
            arr[j] = temp;
        }
        j = j + 1;
    }
    // Swap arr[i+1] and arr[high]
    let temp = arr[i + 1];
    arr[i + 1] = arr[high];
    arr[high] = temp;
    return i + 1;
}

fn test_parallel_mergesort_simulation() {
    let mut data = [64, 34, 25, 12, 22, 11, 90];
    mergesort_simulation(&mut data, 0, len(data) - 1);
    let mut i = 0;
    while i < len(data) {
        print(data[i]);
        i = i + 1;
    }
}

fn mergesort_simulation(arr: &mut [int], left: int, right: int) {
    if left < right {
        let mid = (left + right) / 2;
        mergesort_simulation(arr, left, mid);
        mergesort_simulation(arr, mid + 1, right);
        merge_simulation(arr, left, mid, right);
    }
}

fn merge_simulation(arr: &mut [int], left: int, mid: int, right: int) {
    let n1 = mid - left + 1;
    let n2 = right - mid;
    
    // Create temporary arrays
    let mut left_arr = [0, 0, 0, 0, 0, 0, 0];  // Max size needed
    let mut right_arr = [0, 0, 0, 0, 0, 0, 0];  // Max size needed
    
    let mut i = 0;
    while i < n1 {
        left_arr[i] = arr[left + i];
        i = i + 1;
    }
    i = 0;
    while i < n2 {
        right_arr[i] = arr[mid + 1 + i];
        i = i + 1;
    }
    
    i = 0;
    let mut j = 0;
    let mut k = left;
    while i < n1 && j < n2 {
        if left_arr[i] <= right_arr[j] {
            arr[k] = left_arr[i];
            i = i + 1;
        } else {
            arr[k] = right_arr[j];
            j = j + 1;
        }
        k = k + 1;
    }
    
    while i < n1 {
        arr[k] = left_arr[i];
        i = i + 1;
        k = k + 1;
    }
    
    while j < n2 {
        arr[k] = right_arr[j];
        j = j + 1;
        k = k + 1;
    }
}

