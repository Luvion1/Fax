fn test_lock_simulation() {
    let mut locked = false;
    if !locked {
        locked = true;
        print(1);  // Critical section
        locked = false;
    }
}

fn test_mutex_simulation() {
    let mutex = 0;  // 0 = unlocked, 1 = locked
    if mutex == 0 {
        // Acquire lock
        mutex = 1;
        print(1);  // Critical section
        mutex = 0;  // Release lock
    }
}

fn test_semaphore_simulation() {
    let mut permits = 2;
    if permits > 0 {
        permits = permits - 1;
        print(1);  // Access resource
        permits = permits + 1;  // Release resource
    }
}

fn test_deadlock_simple_simulation() {
    let lock_a = false;
    let lock_b = false;
    // Thread 1 acquires lock A
    if !lock_a {
        lock_a = true;
        // Thread 1 tries to acquire lock B
        if !lock_b {
            lock_b = true;
            print(1);  // Both locks acquired
            lock_b = false;
        }
        lock_a = false;
    }
}

