fn test_map_reduce_simulation() {
    let data = [1, 2, 3, 4, 5];
    // Map: square each element
    let mut mapped = [0, 0, 0, 0, 0];
    let mut i = 0;
    while i < len(data) {
        mapped[i] = data[i] * data[i];
        i = i + 1;
    }
    // Reduce: sum all elements
    let mut sum = 0;
    i = 0;
    while i < len(mapped) {
        sum = sum + mapped[i];
        i = i + 1;
    }
    print(sum);
}

