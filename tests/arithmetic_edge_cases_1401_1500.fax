fn test_linear_congruential_generator() {
    // Simple PRNG algorithm
    let seed = 12345;
    let a = 1664525;
    let c = 1013904223;
    let m = 4294967296;  // 2^32
    let next = (a * seed + c) % m;
    print(next);
}

fn test_middle_square_method() {
    // Early PRNG method
    let seed = 1234;
    let square = seed * seed;
    let middle = (square / 100) % 10000;  // Extract middle 4 digits
    print(middle);
}

fn test_xorshift_generator() {
    // Fast PRNG using XOR and bit shifts
    let mut x = 123456789;
    x = x ^ (x << 13);
    x = x ^ (x >> 17);
    x = x ^ (x << 5);
    print(x);
}

