fn test_diffie_hellman_key_exchange() {
    // Method for exchanging cryptographic keys
    let p = 23;  // Prime modulus
    let g = 5;   // Generator
    let a = 6;   // Private key of party A
    let b = 15;  // Private key of party B
    let public_a = power_mod(g, a, p);
    let public_b = power_mod(g, b, p);
    let shared_secret_a = power_mod(public_b, a, p);
    let shared_secret_b = power_mod(public_a, b, p);
    print(shared_secret_a);
    print(shared_secret_b);
}

fn power_mod(base: int, exp: int, mod_val: int) -> int {
    let mut result = 1;
    let mut b = base % mod_val;
    let mut e = exp;
    while e > 0 {
        if e % 2 == 1 {
            result = (result * b) % mod_val;
        }
        e = e / 2;
        b = (b * b) % mod_val;
    }
    return result;
}

