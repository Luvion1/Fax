struct Node {
    next: Node
    val: i64
}

fn main() {
    let mut root = Node { next: null, val: 0 };
    
    print("Starting Generational GC Test...");
    
    let mut i = 0;
    while i < 10 {
        let newNode = Node { next: null, val: i };
        root.next = newNode;
        
        print(i);
        collect_gc();
        
        i = i + 1;
    }
    
    print("Generational GC Test Completed Successfully");
}