module std::util;

pub fn max(a: i64, b: i64) -> i64 {
    if a > b {
        return a;
    } else {
        return b;
    }
}

pub fn min(a: i64, b: i64) -> i64 {
    if a < b {
        return a;
    } else {
        return b;
    }
}

pub fn abs(n: i64) -> i64 {
    if n < 0 {
        return -n;
    } else {
        return n;
    }
}