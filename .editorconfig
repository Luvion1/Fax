# EditorConfig helps maintain consistent coding styles across different editors and IDEs
# See: https://editorconfig.org

root = true

# All files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# TypeScript/JavaScript files
[*.{ts,js,tsx,jsx}]
indent_style = space
indent_size = 2
max_line_length = 100

# Rust files
[*.rs]
indent_style = space
indent_size = 4
max_line_length = 100

# Zig files
[*.zig]
indent_style = space
indent_size = 4
max_line_length = 100

# Haskell files
[*.hs]
indent_style = space
indent_size = 2
max_line_length = 100

# Python files
[*.py]
indent_style = space
indent_size = 4
max_line_length = 88

# TOML files
[*.toml]
indent_style = space
indent_size = 2

# JSON files
[*.json]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = off
